@model IEnumerable<Proyecto1.Models.Habitacion>
@{
    ViewData["Title"] = "Gestión de Habitaciones";
}

<h1>Gestión de Habitaciones</h1>
<div class="mb-3 d-flex gap-2">
    <a asp-action="Create" class="btn btn-primary">Registrar Nueva Habitación</a>

    <form asp-action="Buscar" method="get" class="d-flex">
        <input type="number" name="terminoBusqueda" class="form-control me-2" placeholder="Número de habitación..." required />
        <button type="submit" class="btn btn-info text-white">Buscar Habitación</button>
        <a asp-action="Index" class="btn btn-secondary ms-2">Limpiar Filtro</a>
    </form>
</div>
<table class="table table-striped">
    <thead>
        <tr>
            <th>Número</th>
            <th>Tipo</th>
            <th>Tarifa</th>
            <th>TV Satelital</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.NumeroHabitacion</td>
                <td>@item.Tipo</td>
                <td>$@item.TarifaPorNoche.ToString("N2")</td>
                <td>@(item.TieneTVSatelital ? "Sí" : "No")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.NumeroHabitacion" class="btn btn-warning btn-sm">Editar</a>
                    <a asp-action="Delete" asp-route-id="@item.NumeroHabitacion" class="btn btn-danger btn-sm">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>