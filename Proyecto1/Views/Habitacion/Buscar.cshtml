@model Proyecto1.Models.Habitacion
@{
    ViewData["Title"] = "Buscar Habitación";
}

<h1>Buscar Habitación</h1>
<hr />
<div class="row mb-4">
    <div class="col-md-6">
        <form asp-action="Buscar" method="post" class="d-flex">
            <input type="number" name="numeroBuscar" class="form-control me-2" placeholder="Ingrese el número..." required />
            <button type="submit" class="btn btn-primary">Buscar</button>
        </form>
    </div>
</div>

@if (ViewBag.Mensaje != null)
{
    <div class="alert alert-warning">@ViewBag.Mensaje</div>
}

@if (Model != null)
{
    <div class="card">
        <div class="card-header bg-success text-white"><h4>Habitación Encontrada</h4></div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-4">Número:</dt>
                <dd class="col-sm-8">@Model.NumeroHabitacion</dd>
                <dt class="col-sm-4">Tipo:</dt>
                <dd class="col-sm-8">@Model.Tipo</dd>
                <dt class="col-sm-4">Tarifa:</dt>
                <dd class="col-sm-8">$@Model.TarifaPorNoche.ToString("N2")</dd>
                <dt class="col-sm-4">TV Satelital:</dt>
                <dd class="col-sm-8">@(Model.TieneTVSatelital ? "Sí" : "No")</dd>
            </dl>
        </div>
    </div>
}
<div class="mt-3"><a asp-action="Index" class="btn btn-secondary">Regresar</a></div>