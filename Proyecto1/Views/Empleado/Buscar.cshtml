@model Proyecto1.Models.Empleado

@{
    ViewData["Title"] = "Buscar Empleado";
}

<h1>Buscar Empleado</h1>
<hr />

<div class="row mb-4">
    <div class="col-md-6">
        <form asp-action="Buscar" method="post" class="d-flex">
            <input type="text" name="identificacionBuscar" class="form-control me-2" placeholder="Ingrese la identificación..." required />
            <button type="submit" class="btn btn-primary">Buscar</button>
        </form>
    </div>
</div>

@if (ViewBag.Mensaje != null)
{
    <div class="alert alert-warning">@ViewBag.Mensaje</div>
}

@if (Model != null)
{
    <div class="card">
        <div class="card-header bg-success text-white">
            <h4>Empleado Encontrado</h4>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-4">Identificación:</dt>
                <dd class="col-sm-8">@Model.Identificacion</dd>

                <dt class="col-sm-4">Nombre Completo:</dt>
                <dd class="col-sm-8">@Model.Nombre @Model.PrimerApellido @Model.SegundoApellido</dd>

                <dt class="col-sm-4">Categoría:</dt>
                <dd class="col-sm-8">@Model.Categoria</dd>

                <dt class="col-sm-4">Salario Mensual:</dt>
                <dd class="col-sm-8">₡@Model.SalarioMensual.ToString("N2")</dd>

                <dt class="col-sm-4">Ubicación:</dt>
                <dd class="col-sm-8">@Model.Provincia, @Model.Canton, @Model.Distrito</dd>
            </dl>
        </div>
    </div>
}

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Regresar a la Lista</a>
</div>