@model Proyecto1.Models.Reservacion
@{
    ViewData["Title"] = "Editar Reservación";
}

<h1>Editar Reservación</h1>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="Codigo" class="control-label"></label>
                <input asp-for="Codigo" class="form-control" readonly />
            </div>

            <div class="form-group mb-3">
                <label asp-for="IdentificacionCliente" class="control-label"></label>
                <input asp-for="IdentificacionCliente" class="form-control" readonly />
            </div>

            <div class="form-group mb-3">
                <label asp-for="NumeroHabitacion" class="control-label"></label>
                <input asp-for="NumeroHabitacion" class="form-control" type="number" readonly />
            </div>

            <div class="row">
                <div class="col-md-6 form-group mb-3">
                    <label asp-for="FechaIngreso" class="control-label"></label>
                    <input asp-for="FechaIngreso" class="form-control" type="date" />
                    <span asp-validation-for="FechaIngreso" class="text-danger"></span>
                </div>
                <div class="col-md-6 form-group mb-3">
                    <label asp-for="FechaSalida" class="control-label"></label>
                    <input asp-for="FechaSalida" class="form-control" type="date" />
                    <span asp-validation-for="FechaSalida" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 form-group mb-3">
                    <label asp-for="CantidadPersonas" class="control-label"></label>
                    <input asp-for="CantidadPersonas" class="form-control" type="number" />
                    <span asp-validation-for="CantidadPersonas" class="text-danger"></span>
                </div>
                <div class="col-md-6 form-group mb-3">
                    <label asp-for="Estado" class="control-label"></label>
                    <select asp-for="Estado" asp-items="Html.GetEnumSelectList<Proyecto1.Models.EstadoReservacion>()" class="form-select"></select>
                    <span asp-validation-for="Estado" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group mb-3">
                <label asp-for="FechaReservacion" class="control-label fw-bold"></label>
                <input asp-for="FechaReservacion" class="form-control" type="date" />
                <span asp-validation-for="FechaReservacion" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="PorcentajeDescuento" class="control-label fw-bold"></label>
                <input asp-for="PorcentajeDescuento" class="form-control" type="number" min="0" max="100" placeholder="Ej: 15" />
                <span asp-validation-for="PorcentajeDescuento" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="SolicitudesEspeciales" class="control-label fw-bold"></label>
                <textarea asp-for="SolicitudesEspeciales" class="form-control" rows="2" placeholder="Ej: Cerca de la piscina..."></textarea>
                <span asp-validation-for="SolicitudesEspeciales" class="text-danger"></span>
            </div>

            <div class="form-group mt-4">
                <input type="submit" value="Guardar Cambios" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Regresar</a>
            </div>
        </form>
    </div>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}