@model IEnumerable<Proyecto1.Models.Reservacion>
@{
    ViewData["Title"] = "Gestión de Reservaciones";
}

<h1>Gestión de Reservaciones</h1>
<div class="mb-3 d-flex gap-2">
    <a asp-action="Create" class="btn btn-primary">Registrar Nueva Reservación</a>

    <form asp-action="Buscar" method="get" class="d-flex">
        <input type="text" name="terminoBusqueda" class="form-control me-2" placeholder="Código (ej. RES-001)..." required />
        <button type="submit" class="btn btn-info text-white">Buscar Reservación</button>
        <a asp-action="Index" class="btn btn-secondary ms-2">Limpiar Filtro</a>
    </form>
</div>
<table class="table table-striped">
    <thead>
        <tr>
            <th>Código</th>
            <th>ID Cliente</th>
            <th>Habitación</th>
            <th>Ingreso</th>
            <th>Salida</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Codigo</td>
                <td>@item.IdentificacionCliente</td>
                <td>#@item.NumeroHabitacion</td>
                <td>@item.FechaIngreso.ToString("dd/MM/yyyy")</td>
                <td>@item.FechaSalida.ToString("dd/MM/yyyy")</td>
                <td>@item.Estado</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Codigo" class="btn btn-warning btn-sm">Editar</a>
                    <a asp-action="Delete" asp-route-id="@item.Codigo" class="btn btn-danger btn-sm">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>